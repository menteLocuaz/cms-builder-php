{
  "name": "arancamon/cms-builder-php",
  "description": "cms",
  "autoload": {
    "psr-4": {
      "Arancamon\\CmsBuilderPhp\\": "app/"
    }
  },
  "authors": [
    {
      "name": "dexter"
    }
  ],
  "require": {
    "nesbot/carbon": "^3.13",
    "vlucas/phpdotenv": "^5.6"
  },
  "scripts": {
